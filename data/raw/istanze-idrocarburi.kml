  <Placemark>
      <name>FONTEVIVO</name>
      <description><![CDATA[<h3>Istanza di permesso di ricerca in terraferma</h3><h2>FONTEVIVO</h2><u>Nota:</u><br>Istanza presentata in fata 19 dicembre 2015 ed integrata, su richiesta dell'amministrazione, in data 27 gennaio 2016.<br><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;di&nbsp;presentazione&nbsp;&nbsp;&nbsp;</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">19/12/2015</td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">411,4 km<sup>2</sup></td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fogli IGM</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">73&nbsp;</td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" valign=top>Richiedenti</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">PENGAS&nbsp;ITALIANA&nbsp;(100%&nbsp;r.u.)<br></td></tr></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione BUIG</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">31/01/2016</td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione GUUE</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/03/2016</td></tr></table><br>UBICAZIONE<br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>Emilia&nbsp;Romagna (411,40&nbsp;km<sup>2</sup>)<br>Parma (411,40&nbsp;km<sup>2</sup>)<br><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" width=350 align=left valign=top>Comuni:<br>Busseto, Collecchio, Fidenza, Fontanellato, Fontevivo, Medesano, Noceto, Parma, Polesine Zibello, Salsomaggiore Terme, San Secondo Parmense, Sissa Trecasali, Soragna, Torrile.
</td></td></tr></table><br>COORDINATE GEOGRAFICHE DEI VERTICI<table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 23&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 00&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 18&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 00&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 18&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 57&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 13&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 57&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 13&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 54&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px sol