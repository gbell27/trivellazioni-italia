      <name>SOLFARA MARE</name>
      <description><![CDATA[<h3>Istanza di permesso di ricerca in terraferma</h3><h2>SOLFARA MARE</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;di&nbsp;presentazione&nbsp;&nbsp;&nbsp;</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">27/11/2008</td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">337 km<sup>2</sup></td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fogli IGM</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">230&nbsp;</td></tr><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" valign=top>Richiedenti</th><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">APENNINE&nbsp;ENERGY&nbsp;(100%&nbsp;r.u.)<br></td></tr></tr></table><br>UBICAZIONE<br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>Calabria (337,00&nbsp;km<sup>2</sup>)<br>Cosenza (337,00&nbsp;km<sup>2</sup>)<br><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" width=350 align=left valign=top>Comuni:<br>Calopezzati, Caloveto, Cariati, Corigliano Calabro, Cropalati, Crosia, Mandatoriccio, Paludi, Pietrapaola, Rossano, Scala Coeli, Terravecchia</td></td></tr></table><br>COORDINATE GEOGRAFICHE DEI VERTICI<table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4&ordm; 03&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 38&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center colspan=2>&nbsp;&nbsp;&nbsp;Intersezione tra il parallelo 39&ordm;38&apos; e la linea di costa a bassa marea&nbsp;&nbsp;&nbsp;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center colspan=2>&nbsp;&nbsp;&nbsp;Intersezione tra la linea di costa a bassa marea ed il meridiano 4&ordm;29&apos;&nbsp;&nbsp;&nbsp;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4&ordm; 29&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 28&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4&ordm; 22&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 28&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4&ordm; 22&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 29&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>g</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4&ordm; 20&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 29&apos;</td></tr><tr><td style="padding: 2px 