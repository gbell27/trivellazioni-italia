  <Placemark>
      <name>BUCCHIANICO</name>
      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>BUCCHIANICO</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>422</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">25/07/1996</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2&ordf; proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>178,96 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENI</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>100%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>REGIONI E PROVINCE IN CUI IL TITOLO RICADE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top>ABRUZZO (178,96 km<sup>2</sup>)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Chieti (155,7 km<sup>2</sup>)<br>Pescara (23,26 km<sup>2</sup>)<br></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><t