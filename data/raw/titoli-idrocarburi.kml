rey;">13/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/966_20170213.pdf" target=_blank>Proroga e riduzione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/11/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXI N. 2</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/03/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/966_20210322.pdf" target=_blank>Proroga</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/11/2019</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXV N. 3</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Piattaforme marine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO CLUSTER</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO EST 2</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>3</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO NORD</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">SIMONETTA 1</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>5</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">VIVIANA 1</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Centrali di raccolta e trattamento</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">PINETO</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Pozzi in produzione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">SIMONETTA 001</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Pozzi produttivi non eroganti</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO EST 002</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO EST 004</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>3</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO EST 005 DIR</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FRATELLO EST 006 DIR</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>5</td><td style="padding: 2p