px 2px 4px; border: 1px solid grey;" align=center>43&ordm; 56&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>z</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 19&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>43&ordm; 58&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 17&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>43&ordm; 58&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 17&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 00&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 20&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 00&apos;</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PERIODI DI VIGENZA</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;decreto</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>18/03/2015</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Conferimento</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>18/03/2015</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>18/03/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>6</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table>Presentata, in data 28 settembre 2023, istanza di proroga pubblicata nel BUIG Anno LXVII - N. 9<br><br><div style=&apos;margin-bottom:5px;&apos;>SOSPENSIONI DEL DECORSO TEMPORALE</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" align=left>Giorni&nbsp;di&nbsp;sospensione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>13/02/2019</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>01/10/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Decreto-legge 14 dicembre 2018, n.135, art. 11-ter, commi 6-8, convertito con modificazioni dalla Legge 11 febbraio 2019 n. 12 (Moratoria del Piano per la transizione energetica sostenibile delle aree idonee - PiTESAI).</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>961</td></tr></table>Il permesso &egrave; stato sospeso per un totale di 961 giorni (circa&nbsp;2&nbsp;anni&nbsp;e&nbsp;8&nbsp;mesi)<br><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/03/2015</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2006_20150318.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/03/2015</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LIX N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">14/03/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2006_20170314.pdf" target=_blank>Cambio intestazione quote</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">19/03/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXI N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/12/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2006_20231229.pdf" target=_blank>Revoca parziale e riperimetrazione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/12/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXVII N. 12</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div>]]></description>
