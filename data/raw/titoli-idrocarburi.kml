tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/10/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Trasferimento quota</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">17/12/2003</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 11</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">30/06/2005</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Trasferimento quota</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">26/04/2005</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLIX N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">16/04/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/849_20080416.pdf" target=_blank>Cambio intestazione quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/02/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LII N. 5</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/03/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/849_20130301.pdf" target=_blank>Cambio intestazione quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/03/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVII N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">28/06/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/849_20130628.pdf" target=_blank>Trasferimento quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">05/06/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVII N. 6</td></tr><tr><td style="padding: 2px 4px 2px 4px