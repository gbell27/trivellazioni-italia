 border: 1px solid grey;">01/07/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXII N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">19/03/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/867_20210319.pdf" target=_blank>Cambio intestazione quote</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">23/02/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXV N. 3</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Centrali di raccolta e trattamento</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">SAN GIORGIO MARE</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Pozzi produttivi non eroganti</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">MONTE URANO 001</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">MONTE URANO 002 DIR</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>3</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">SAN LORENZO 001 DIR</td></tr></table></div><br>]]></description>
