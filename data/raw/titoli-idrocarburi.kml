  <Placemark>
      <name>G.R 14.AG</name>
      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>G.R 14.AG</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>656</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/11/1999</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2&ordf; proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>373,08 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENI MEDITERRANEA IDROCARBURI(r.u.)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>60%</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENERGEAN ITALY</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>40%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>ZONE MARINE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top colspan=2>ZONA G (368,58 km<sup>2</sup>)</td></tr><tr><td valign=top colspan=2>ZONA C (4,5 km<sup>2</sup>)</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 30&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>37&ordm; 03&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 39&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>37&ordm; 03&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra il meridiano 13&ordm;39&apos; e la linea di delimitazione della zona G</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra la linea di delimitazione della zona G ed il meridiano 13&ordm;45&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 45&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>36&ordm; 58&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>13&ordm; 44&apos;</td><td style="