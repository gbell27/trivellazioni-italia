  <Placemark>
      <name>TORRE DEL MORO</name>
      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>TORRE DEL MORO</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>2137</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>19,72 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">PO VALLEY OPERATIONS PTY</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>100%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>REGIONI E PROVINCE IN CUI IL TITOLO RICADE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top>EMILIA-ROMAGNA (19,72 km<sup>2</sup>)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Forl&igrave;-Cesena (19,72 km<sup>2</sup>)<br></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 18&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 11&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 16&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 11&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 16&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 10&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 15&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 10&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 15&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 08&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-0&ordm; 18&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>44&ordm; 08&apos;</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PERIODI DI VIGENZA</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;decreto</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>08/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Conferimento</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>08/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>08/02/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>6</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>SOSPENSIONI DEL DECORSO TEMPORALE</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" align=left>Giorni&nbsp;di&nbsp;sospensione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>13/02/2019</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>01/10/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Decreto-legge 14 dicembre 2018, n.135, art. 11-ter, commi 6-8, convertito con modificazioni dalla Legge 11 febbraio 2019 n. 12 (Moratoria del Piano per la transizione energetica sostenibile delle aree idonee - PiTESAI).</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>961</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>11/02/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>23/07/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dall'11 febbraio 2022 al 22 luglio 2025, data del decreto di conferma dell&apos;area e sospensione del decorso temporale.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>1.258</td></tr></table>Il permesso &egrave; stato sospeso per un totale di 2.219 giorni (circa&nbsp;6&nbsp;anni&nbsp;e&nbsp;1&nbsp;mese)<br><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2137_20170208.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/02/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXI N. 2</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/09/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2137_20220929.pdf" target=_blank>Revoca parziale e riperimetrazione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/09/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXVI N. 9</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/07/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2137_20250722.pdf" target=_blank>Conferma dell&apos;area</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/07/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXIX N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/07/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2137_20250722.pdf" target=_blank>Sospensione decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">11/02/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXIX N. 7</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div>]]></description>
