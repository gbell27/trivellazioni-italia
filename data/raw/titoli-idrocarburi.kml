x 2px 4px; border: 1px solid grey;" valign=top>07/09/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dal 12/12/2013 fino al pronunciamento del TAR Abruzzo su annullamento parere VIA negativo della Regione Abruzzo e comunque non oltre 270 giorni dalla data di inizio sospensione.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>269</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>07/09/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>07/03/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dal 7/9/2014 fino al pronunciamento del TAR Abruzzo su annullamento parere VIA negativo della Regione Abruzzo e comunque non oltre 18 mesi dalla data di inizio sospensione.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>547</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>07/03/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>31/12/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dal 7/3/2014 fino al pronunciamento del TAR Abruzzo su annullamento parere VIA negativo della Regione Abruzzo e comunque non oltre  il 31/12/2016.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>299</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>31/12/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>03/12/2027</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dal 31/12/2016, data di scadenza della precedente sospensione, fino al pronunciamento Regione Abruzzo su compatibilit&agrave; ambientale pozzo SANTA LIBERATA 1 DIR e comunque fino ad un massimo di 24 mesi dal 3/12/2025, data del decreto di ripristino.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>3.989 (3439 trascorsi)</td></tr></table>Attualmente sospeso (550 giorni di sospensione restanti).<br>Il permesso &egrave; stato sospeso per un totale di 7.032 giorni (circa&nbsp;19&nbsp;anni&nbsp;e&nbsp;3&nbsp;mesi)<br><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/04/1999</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_19990422.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/04/1999</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLIII N. 5</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">21/03/2002</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20020321.pdf" target=_blank>Trasferimento quota e nomina r.u.</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">11/01/2002</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVI N. 4</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/11/2007</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20071120.pdf" target=_blank>Assunzione quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">27/07/2007</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LI N. 12</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/11/2007</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20071120.pdf" target=_blank>Proroga</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">22/04/2005</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LI N. 12</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">19/06/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20080619.pdf" target=_blank>Trasferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">27/02/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LII N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/07/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20080709.pdf" target=_blank>Sospensione decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/02/2006</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LII N. 8</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/11/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20121108.pdf" target=_blank>Termine della sospensione del decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/11/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVI N. 11</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">16/04/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20130416.pdf" target=_blank>Sospensione decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">27/12/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVII N. 4</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">06/03/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20140306.pdf" target=_blank>Termine della sospensione del decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">10/12/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVIII N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">07/05/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20140507.pdf" target=_blank>Rettifica</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">06/03/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVIII N. 5</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">03/07/2014</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20140703.pdf" target=_blank>Sospensione decorso temporale</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/12/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVIII N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">23/02/2015</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/496_20150223.pdf" target=_blank>Modifica denominazione sociale</a></td><td style="padding: 2px 4px 2px 4px; 