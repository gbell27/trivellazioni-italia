  <Placemark>
      <name>MUTIGNANO</name>
      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>MUTIGNANO</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>501</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/06/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordf; proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>76,19 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENI(r.u.)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>50%</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">GAS PLUS ITALIANA</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>50%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>REGIONI E PROVINCE IN CUI IL TITOLO RICADE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top>ABRUZZO (76,19 km<sup>2</sup>)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Teramo (62,85 km<sup>2</sup>)<br>Pescara (13,34 km<sup>2</sup>)<br></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 34&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 39&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra il parallelo 42&ordm;39&apos; e la linea di costa a bassa marea</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra la linea di costa a bassa marea ed il parallelo 42&ordm;31&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 37&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 31&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 37&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 32&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 35&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 32&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>g</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 35&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 36&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>h</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 34&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 36&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>i</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 34&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 37&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>l</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 33&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 37&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>m</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 33&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 38&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>n</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; 34&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>42&ordm; 38&apos;</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PERIODI DI VIGENZA</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;decreto</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>09/06/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Conferimento</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>09/06/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>09/06/2006</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>6</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordf;&nbsp;proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>20/11/2007</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>09/06/2006</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>09/06/2009</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>3</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table>Presentata, in data 16 aprile 2009, istanza di proroga pubblicata nel BUIG Anno LIII - N. 5<br><br><div style=&apos;margin-bottom:5px;&apos;>SOSPENSIONI DEL DECORSO TEMPORALE</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" align=left>Giorni&nbsp;di&nbsp;sospensione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>18/12/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dal 18/12/2008 sino al pronunciamento della Regione Abruzzo. 
Con successivo decreto sar&agrave; determinato il termine finale della sospensione.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>6.375</td></tr></table>Il permesso &egrave; stato sospeso per un totale di 6.375 giorni (circa&nbsp;17&nbsp;anni&nbsp;e&nbsp;6&nbsp;mesi)<br><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/06/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20000609.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/06/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLIV N. 7</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/04/2001</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20010420.pdf" target=_blank>Cambio intestazione quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/10/2000</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLV N. 5</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/09/2001</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Trasferimento quota</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/06/2001</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLV N. 10</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/01/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Nomina r.u.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">25/06/2003</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 2</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/02/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Cambio intestazione quota</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/01/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/07/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Cambio intestazione quota</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/05/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 8</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/11/2007</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/06/2006</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LI N. 12</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">04/05/2009</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Sospensione decorso temporale</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/12/2008</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LIII N. 6</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">09/02/2010</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20100209.pdf" target=_blank>Trasferimento quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/01/2010</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LIV N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">17/02/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20120217.pdf" target=_blank>Riduzione area</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">19/01/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVI N. 2</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/03/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20120329.pdf" target=_blank>Rettifica</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/03/2012</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVI N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/03/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20130301.pdf" target=_blank>Cambio intestazione quota</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/03/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LVII N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">21/11/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/501_20161121.pdf" target=_blank>Cambio intestazione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/10/2016</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LX N. 11</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">31/10/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid