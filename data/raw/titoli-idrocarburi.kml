  <Placemark>
      <name>A.R 78.RC</name>
      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>A.R 78.RC</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>549</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">16/04/1987</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2&ordf; proroga</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>100,02 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENI(r.u.)</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>90%</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">ENERGEAN ITALY</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>10%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>ZONE MARINE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top colspan=2>ZONA A (100,02 km<sup>2</sup>)</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px 