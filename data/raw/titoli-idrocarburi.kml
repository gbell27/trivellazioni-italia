      <description><![CDATA[<h3>Permesso di Ricerca</h3><h2>F.R 44.GM</h2><br><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Codice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Conferimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo&nbsp;di&nbsp;vigenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Superficie</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>2139</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">07/12/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1&ordm; periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>744,60 km<sup>2</sup></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>TITOLARI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Operatore</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Quota</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">GLOBAL MED</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right>100%</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>ZONE MARINE (superfici parziali)</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><td valign=top colspan=2>ZONA F (744,6 km<sup>2</sup>)</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>COORDINATE GEOGRAFICHE DEI VERTICI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Vertice</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Longitudine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Latitudine</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>a</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 32&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 35&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>b</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 40&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 35&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>c</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 40&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 30&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>d</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 49&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 30&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>e</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 49&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 29&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>f</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra il parallelo 39&ordm;29&apos; e la linea di delimitazione della zona F</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>g</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" colspan=2 align=center>Intersezione tra la linea di delimitazione della zona F ed il parallelo 39&ordm;22&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>h</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 28&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 22&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>i</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 28&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 27&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>l</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 27&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 27&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>m</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 27&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 29&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>n</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 26&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 29&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>o</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 26&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 34&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>p</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>18&ordm; 32&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>39&ordm; 34&apos;</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PERIODI DI VIGENZA</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;decreto</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>07/12/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Conferimento</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>07/12/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>07/12/2024</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>6</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>SOSPENSIONI DEL DECORSO TEMPORALE</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" align=left>Giorni&nbsp;di&nbsp;sospensione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>13/02/2019</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>01/10/2021</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Decreto-legge 14 dicembre 2018, n.135, art. 11-ter, commi 6-8, convertito con modificazioni dalla Legge 11 febbraio 2019 n. 12 (Moratoria del Piano per la transizione energetica sostenibile delle aree idonee - PiTESAI).</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>961</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>11/02/2022</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top>24/12/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=left valign=top>Sospeso dall'11 febbraio 2022 al 23 dicembre 2025, data del decreto di ripristino.</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=right valign=top>1.412</td></tr></table>Il permesso &egrave; stato sospeso per un totale di 2.373 giorni (circa&nbsp;6&nbsp;anni&nbsp;e&nbsp;6&nbsp;mesi)<br><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">07/12/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2139_20181207.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">07/12/2018</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXII N. 12</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/12/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2139_20231229.pdf" target=_blank>Revoca</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/12/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXVII N. 12</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">23/12/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2139_20251223.pdf" target=_blank>Ripristino</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">29/12/2023</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXIX N. 12</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div>]]></description>
