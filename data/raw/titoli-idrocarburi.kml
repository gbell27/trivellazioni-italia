px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">GAGLIANO</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Pozzi in produzione</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FIUMETTO 001</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>2</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FIUMETTO 002 DIR</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>3</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FIUMETTO 004 DIR A</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>4</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">MASSERIA VECCHIA 001 DIR</td></tr></table></div><br><div style=&apos;float:left; margin-right:20px; margin-bottom:20px;&apos;><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;" colspan=2>Pozzi produttivi non eroganti</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>1</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">FIUMETTO 003 DIR</td></tr></table></div><br>]]></description>
