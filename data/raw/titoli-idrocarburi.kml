color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>21/04/1998</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Attribuzione</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>01/01/1997</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>01/01/2017</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>20</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">21/04/1998</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/905_19980421.pdf" target=_blank>Attribuzione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/01/1997</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLII N. 5</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div>]]></description>
