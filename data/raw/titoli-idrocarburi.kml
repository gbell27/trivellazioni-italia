lign=center>-2&ordm; 36&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 26&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>p</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 33&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 26&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>q</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 33&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 27&apos;</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>r</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>-2&ordm; 32&apos;</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" align=center>45&ordm; 27&apos;</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PERIODI DI VIGENZA</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Periodo</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data&nbsp;decreto</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Inizio</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Fine</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Anni</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Note</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>1&ordm;&nbsp;periodo</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>14/05/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left>Conferimento</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>14/05/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=center>14/05/2031</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=right>6</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;" valign=top align=left></td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>PROVVEDIMENTI</div><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">14/05/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/2142_20250514.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">14/05/2025</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno LXIX N. 5</td></tr></table><br><div style=&apos;margin-bottom:5px;&apos;>IMPIANTI</div>]]></description>
