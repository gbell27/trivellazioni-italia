><table style="border-collapse: collapse; border: 1px solid grey;"><tr><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Data</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Natura&nbsp;del&nbsp;provvedimento</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Decorrenza</th><th style="padding: 4px; background-color:#E4E4E4; color:grey; border: 1px solid grey;">Pubblicazione&nbsp;BUIG</th></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/09/1999</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/927_19990908.pdf" target=_blank>Conferimento</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">08/09/1999</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLIII N. 10</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">12/02/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Cambio intestazione</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/01/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 3</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">20/07/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/927_20040720.pdf" target=_blank>Cambio intestazione</a></td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">18/05/2004</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">Anno XLVIII N. 8</td></tr><tr><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;">01/03/2013</td><td style="padding: 2px 4px 2px 4px; border: 1px solid grey;"><a href="https://unmig.mase.gov.it/wp-content/uploads/decreti/927_20130301.pdf" target=_blank>Cambio intestazione quota</a></td><td style="padding: 2px 4